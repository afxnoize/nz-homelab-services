default:
    @just --list

set dotenv-load := false

secrets := env("VAULT_SECRETS", "./secrets.yaml")
quadlet_dir := env("XDG_CONFIG_HOME", env("HOME") / ".config") / "containers/systemd"

####################
# Lifecycle
####################

# Deploy quadlet files and reload systemd
[group('lifecycle')]
deploy:
    #!/usr/bin/env bash
    set -euo pipefail
    export TS_DOMAIN=$(tailscale status --json | jq -r '.MagicDNSSuffix')
    if [[ -z "${TS_DOMAIN}" || "${TS_DOMAIN}" == "null" ]]; then
      echo "ERROR: failed to get Tailscale MagicDNS suffix" >&2
      exit 1
    fi
    mkdir -p {{ quadlet_dir }}
    echo "==> Generating quadlet files from templates"
    sops exec-env {{ secrets }} ' \
      gomplate -f quadlet/vaultwarden-ts.container.tmpl  -o {{ quadlet_dir }}/vaultwarden-ts.container && \
      gomplate -f quadlet/vaultwarden.container.tmpl      -o {{ quadlet_dir }}/vaultwarden.container && \
      gomplate -f quadlet/vaultwarden-ts-serve.json.tmpl  -o {{ quadlet_dir }}/vaultwarden-ts-serve.json \
    '
    echo "==> Copying quadlet files"
    cp quadlet/vaultwarden-data.volume {{ quadlet_dir }}/
    cp quadlet/vaultwarden-ts-state.volume {{ quadlet_dir }}/
    systemctl --user daemon-reload
    echo "==> Deployed (domain: vaultwarden.${TS_DOMAIN})"

# Start ts sidecar then app
[group('lifecycle')]
start:
    systemctl --user start vaultwarden-ts vaultwarden

# Stop app then ts sidecar (reverse order)
[group('lifecycle')]
stop:
    systemctl --user stop vaultwarden vaultwarden-ts

# Restart app and ts sidecar
[group('lifecycle')]
restart:
    systemctl --user restart vaultwarden-ts vaultwarden

####################
# Observe
####################

# systemctl --user status vaultwarden vaultwarden-ts --no-pager
[group('observe')]
status:
    -systemctl --user status vaultwarden vaultwarden-ts --no-pager

# journalctl --user -u vaultwarden -u vaultwarden-ts --no-pager -n <count>
[group('observe')]
logs count="50":
    journalctl --user -u vaultwarden -u vaultwarden-ts --no-pager -n {{ count }}

# journalctl --user -u vaultwarden -u vaultwarden-ts -f
[group('observe')]
logs-follow:
    journalctl --user -u vaultwarden -u vaultwarden-ts -f

####################
# Maintenance
####################

# podman auto-update
[group('maintenance')]
update:
    podman auto-update
