default:
    @just --list

set dotenv-load := false

secrets := env("VAULT_SECRETS", "./secrets.yaml")
quadlet_dir := env("XDG_CONFIG_HOME", env("HOME") / ".config") / "containers/systemd"

####################
# Lifecycle
####################

# Deploy quadlet files and reload systemd
[group('lifecycle')]
deploy:
    #!/usr/bin/env bash
    set -euo pipefail
    export TS_DOMAIN=$(tailscale status --json | jq -r '.MagicDNSSuffix')
    if [[ -z "${TS_DOMAIN}" || "${TS_DOMAIN}" == "null" ]]; then
      echo "ERROR: failed to get Tailscale MagicDNS suffix" >&2
      exit 1
    fi
    mkdir -p {{ quadlet_dir }}
    echo "==> Generating config and quadlet files from templates"
    sops exec-env {{ secrets }} ' \
      gomplate -f config.yaml.tmpl                    -o {{ quadlet_dir }}/gatus-config.yaml && \
      gomplate -f quadlet/gatus-ts.container.tmpl     -o {{ quadlet_dir }}/gatus-ts.container && \
      gomplate -f quadlet/gatus-ts-serve.json.tmpl    -o {{ quadlet_dir }}/gatus-ts-serve.json \
    '
    echo "==> Copying quadlet files"
    cp quadlet/gatus.container {{ quadlet_dir }}/
    cp quadlet/gatus-data.volume {{ quadlet_dir }}/
    cp quadlet/gatus-ts-state.volume {{ quadlet_dir }}/
    systemctl --user daemon-reload
    echo "==> Deployed (domain: gatus.${TS_DOMAIN})"

# Start ts sidecar then app
[group('lifecycle')]
start:
    systemctl --user start gatus-ts gatus

# Stop app then ts sidecar (reverse order)
[group('lifecycle')]
stop:
    systemctl --user stop gatus gatus-ts

# Restart app and ts sidecar
[group('lifecycle')]
restart:
    systemctl --user restart gatus-ts gatus

####################
# Observe
####################

# systemctl --user status gatus gatus-ts --no-pager
[group('observe')]
status:
    -systemctl --user status gatus gatus-ts --no-pager

# journalctl --user -u gatus -u gatus-ts --no-pager -n <count>
[group('observe')]
logs count="50":
    journalctl --user -u gatus -u gatus-ts --no-pager -n {{ count }}

# journalctl --user -u gatus -u gatus-ts -f
[group('observe')]
logs-follow:
    journalctl --user -u gatus -u gatus-ts -f

####################
# Maintenance
####################

# podman auto-update
[group('maintenance')]
update:
    podman auto-update
